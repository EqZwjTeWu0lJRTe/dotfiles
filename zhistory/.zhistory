function ya() {\
    local tmp=\$(mktemp -t \"yazi-cwd.XXXXX\");\
    command yazi \"\$@\" --cwd-file=\"\$tmp\";\
    if [ -f \"\$tmp\" ]; then\
        local dir=\$(cat \"\$tmp\");\
        rm -f \"\$tmp\";\
        if [ -d \"\$dir\" ] && [ \"\$dir\" != \"\$PWD\" ]; then\
            cd \"\$dir\";\
        fi;\
    fi;\
};
